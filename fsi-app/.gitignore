# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase CLI cache (created by supabase link / db query)
supabase/.temp/

# B.2 runner artifacts (regenerable; per-run logs & ts compile output)
/.test-out/
supabase/seed/b2-progress.log

# canonical-source discovery scratch (regeneratable from agent)
canonical-flagged.json
