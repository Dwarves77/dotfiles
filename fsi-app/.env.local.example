# Supabase — required for live data; app falls back to static seed if unset.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Anthropic — required for /api/agent/run, /api/ask, /api/admin/scan.
ANTHROPIC_API_KEY=your-anthropic-api-key

# Worker — shared secret for /api/worker/check-sources and /api/notifications/trigger.
WORKER_SECRET=your-worker-secret

# Browserless — headless browser fallback for /api/data/scan-all and /api/data/fetch-source.
BROWSERLESS_API_KEY=your-browserless-api-key

# Public regulator APIs — used per-source in /api/data/scan-all and /api/data/fetch-source.
EIA_API_KEY=your-eia-api-key
NREL_API_KEY=your-nrel-api-key
DATA_GOV_API_KEY=your-data-gov-api-key
REGULATIONS_GOV_API_KEY=your-regulations-gov-api-key

# SEC fair-access policy — required UA shape for sec.gov programmatic access.
# Format: "Sample Company AdminContact@sample.com". Applied automatically to
# RSS and Browserless requests targeting sec.gov hosts. If unset, the default
# UA is used (sec.gov may serve a throttle page).
SEC_FAIR_ACCESS_UA="Your Company admin@yourdomain.com"
