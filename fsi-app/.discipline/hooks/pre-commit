#!/bin/sh
# Installed from fsi-app/.discipline/hooks/pre-commit
# WORKTREE-ISOLATION guard (RD-19), git-hook leg — the REAL BLOCK.
#
# Blocks a commit in the MAIN checkout when it is an agent context OR the checkout is sitting on an
# agent-owned branch (`worktree-agent-<hex>` / `agent-<hex>`) — the corrupted state from the incident,
# where an orchestrator commit was about to land on an agent's label. A nonzero exit ABORTS the commit.
#
# Fires REGARDLESS of session type (git hooks run in git's invoking process), so it catches a sub-agent's
# commit in the main checkout that the session-scoped PreToolUse gate cannot see. In a linked worktree it
# never fires (the verdict short-circuits: not the main checkout).
#
# This runs ALONGSIDE the existing commit-msg + pre-push discipline hooks; it does not replace them.
# Emergency bypass: git commit --no-verify (use only with operator authorization; the whole point is to
# stop the wrong-label commit before it happens).

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)"
[ -n "$REPO_ROOT" ] || exit 0

RUNNER="$REPO_ROOT/fsi-app/.discipline/governance/worktree-isolation-hook.mjs"
[ -f "$RUNNER" ] || exit 0

# No node → skip this leg (surfacing > wedging a broken env; other legs remain).
command -v node >/dev/null 2>&1 || exit 0

exec node "$RUNNER" --mode=pre-commit
