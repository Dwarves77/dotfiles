  "intelligence_items_constraints": [
    {
      "conname": "intelligence_items_confidence_check",
      "definition": "CHECK ((confidence = ANY (ARRAY['confirmed'::text, 'unconfirmed'::text])))"
    },
    {
      "conname": "intelligence_items_domain_check",
      "definition": "CHECK (((domain >= 1) AND (domain <= 7)))"
    },
    {
      "conname": "intelligence_items_format_type_check",
      "definition": "CHECK (((format_type IS NULL) OR (format_type = ANY (ARRAY['regulatory_fact_document'::text, 'technology_profile'::text, 'operations_profile'::text, 'market_signal_brief'::text, 'research_summary'::text]))))"
    },
    {
      "conname": "intelligence_items_item_type_check",
      "definition": "CHECK ((item_type = ANY (ARRAY['regulation'::text, 'directive'::text, 'standard'::text, 'guidance'::text, 'technology'::text, 'market_signal'::text, 'regional_data'::text, 'research_finding'::text, 'innovation'::text, 'framework'::text, 'tool'::text, 'initiative'::text])))"
    },
    {
      "conname": "intelligence_items_pipeline_stage_check",
      "definition": "CHECK (((pipeline_stage IS NULL) OR (pipeline_stage = ANY (ARRAY['draft'::text, 'active_review'::text, 'published'::text, 'archived'::text]))))"
    },
    {
      "conname": "intelligence_items_priority_check",
      "definition": "CHECK ((priority = ANY (ARRAY['CRITICAL'::text, 'HIGH'::text, 'MODERATE'::text, 'LOW'::text])))"
    },
    {
      "conname": "intelligence_items_severity_check",
      "definition": "CHECK (((severity IS NULL) OR (severity = ANY (ARRAY['ACTION REQUIRED'::text, 'COST ALERT'::text, 'WINDOW CLOSING'::text, 'COMPETITIVE EDGE'::text, 'MONITORING'::text]))))"
    },
    {
      "conname": "intelligence_items_status_check",
      "definition": "CHECK ((status = ANY (ARRAY['proposed'::text, 'adopted'::text, 'in_force'::text, 'monitoring'::text, 'superseded'::text, 'repealed'::text, 'expired'::text])))"
    },
    {
      "conname": "intelligence_items_urgency_tier_check",
      "definition": "CHECK (((urgency_tier IS NULL) OR (urgency_tier = ANY (ARRAY['watch'::text, 'elevated'::text, 'stable'::text, 'informational'::text]))))"
    },
    {
      "conname": "intelligence_items_pkey",
      "definition": "PRIMARY KEY (id)"
    },
    {
      "conname": "intelligence_items_legacy_id_key",
      "definition": "UNIQUE (legacy_id)"
    }
  ],
